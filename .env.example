# OPTIZONE — environment configuration
# Copy to `.env` (local) or set these in Hostinger hPanel → Node.js app → env vars.

# Port the app listens on. On Hostinger/Passenger this is provided automatically.
PORT=3000
NODE_ENV=production

# --- Admin panel login (CHANGE THESE) --------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password
# Optional: use a bcrypt hash instead of a plaintext password (takes priority).
# ADMIN_PASSWORD_HASH=

# Secret used to sign admin session tokens. Use a long random string.
JWT_SECRET=replace-with-a-long-random-secret
TOKEN_TTL=12h

# --- MySQL (Hostinger) ------------------------------------------------------
# Create a MySQL database + user in hPanel, then fill these in. If left blank,
# the app automatically uses a local JSON-file store (server/data/db.json).
USE_MYSQL=true
DB_HOST=localhost
DB_PORT=3306
DB_NAME=uXXXXXXXX_optizone
DB_USER=uXXXXXXXX_admin
DB_PASSWORD=your-db-password

# Max image upload size in bytes (default 6 MB).
MAX_UPLOAD_BYTES=6291456

# --- "Continue with Google" (OAuth) -----------------------------------------
# From Google Cloud Console → APIs & Services → Credentials → OAuth client.
# You MUST add this redirect URI to the OAuth client for every domain you run on:
#   https://YOUR-DOMAIN/api/auth/google/callback
# The client secret is server-side only — never commit it.
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here
# Optional: force the public origin used for the redirect (else derived per request).
# PUBLIC_URL=https://www.optizone.co.il

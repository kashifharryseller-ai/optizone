{
  "name": "optizone-storefront",
  "private": true,
  "version": "1.1.0",
  "description": "OPTIZONE — Vision & Style. Full-stack optical storefront (Vite + React) with a Node/Express + MySQL content API and admin panel. Try Mirror, booking, EN/עברית RTL.",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "dev:all": "concurrently -n web,api -c cyan,magenta \"npm:dev\" \"npm:dev:server\"",
    "build": "vite build",
    "start": "node app.js",
    "preview": "vite preview --host",
    "seed": "node server/seed-cli.js"
  },
  "dependencies": {
    "@fontsource/assistant": "^5.2.9",
    "@fontsource/jost": "^5.2.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.23.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.5",
    "nanoid": "^3.3.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.0",
    "playwright": "^1.61.1"
  },
  "engines": {
    "node": ">=18"
  }
}
